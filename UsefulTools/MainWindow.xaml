<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UsefulTools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UsefulTools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="UsefulTools">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <controls:TabView VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <controls:TabView.TabItems>
                <controls:TabViewItem Header="图片解码" IsClosable="False">
                    <controls:TabViewItem.IconSource>
                        <controls:SymbolIconSource Symbol="Pictures"/>
                    </controls:TabViewItem.IconSource>
                    <Grid Margin="20" ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：输入区域 -->
                        <Grid Grid.Column="0" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 错误提示 -->
                            <TextBlock x:Name="ErrorTextBlock" Grid.Row="0"
                                   Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed"/>

                            <!-- 输入区域（支持垂直滚动条） -->
                            <TextBox x:Name="InputTextBox" Grid.Row="1"
                                 Header="请输入 Base64 字符串"
                                 PlaceholderText="支持纯 Base64 或 Data URI 格式..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                            <!-- 解码按钮 -->
                            <Button x:Name="DecodeButton" Grid.Row="2"
                                Content="解码并显示"
                                HorizontalAlignment="Left"
                                Padding="16,8"/>
                        </Grid>

                        <!-- 右侧：图片显示区域 -->
                        <ScrollViewer Grid.Column="1">
                            <Image x:Name="ResultImage"
                               Stretch="Uniform"
                               Visibility="Collapsed"/>
                        </ScrollViewer>
                    </Grid>
                </controls:TabViewItem>
            </controls:TabView.TabItems>
        </controls:TabView>
    </Grid>
</Window>
